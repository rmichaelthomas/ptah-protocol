{
  "lexicon": 1,
  "id": "world.ptah.log",
  "defs": {
    "main": {
      "type": "record",
      "description": "The world's history book. Accumulated narrative traced back to its sources. Rhetoric made attributable and permanent.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["title", "creatorDID", "worldReference", "createdAt"],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 640,
            "maxGraphemes": 64,
            "description": "The title of this log entry"
          },
          "creatorDID": {
            "type": "string",
            "format": "did",
            "description": "The permanent identity of the log entry's creator"
          },
          "worldReference": {
            "type": "string",
            "format": "at-uri",
            "description": "Reference to the world this log belongs to"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "Timestamp when this log was created"
          },
          "content": {
            "type": "string",
            "maxLength": 102400,
            "maxGraphemes": 10000,
            "description": "The narrative content of the log"
          },
          "summary": {
            "type": "string",
            "maxLength": 2560,
            "maxGraphemes": 256,
            "description": "A brief summary of the log content"
          },
          "logType": {
            "type": "string",
            "knownValues": ["history", "chronicle", "essay", "chapter", "article", "entry"],
            "description": "The type of log entry"
          },
          "sourceReferences": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "at-uri"
            },
            "description": "References to actions, events, or other logs that this log derives from"
          },
          "characters": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "at-uri"
            },
            "description": "References to characters mentioned or involved in this log"
          },
          "locationReference": {
            "type": "string",
            "format": "at-uri",
            "description": "Reference to the primary location of this log's narrative"
          },
          "canonicalStatus": {
            "type": "string",
            "knownValues": [
              "world.ptah.defs#canonicalStatusOfficial",
              "world.ptah.defs#canonicalStatusCommunity",
              "world.ptah.defs#canonicalStatusApocryphal"
            ],
            "description": "The canonical standing of this log"
          },
          "coverImage": {
            "type": "blob",
            "accept": ["image/png", "image/jpeg", "image/webp"],
            "maxSize": 1000000,
            "description": "Cover image for this log entry"
          },
          "media": {
            "type": "array",
            "items": {
              "type": "ref",
              "ref": "#mediaItem"
            },
            "description": "Media attachments for this log entry"
          },
          "humanAuthored": {
            "type": "boolean",
            "description": "Declaration by the author that this work was written by a human, not generated by AI"
          }
        }
      }
    },
    "mediaItem": {
      "type": "object",
      "description": "A media attachment on a log entry",
      "required": ["blob"],
      "properties": {
        "blob": {
          "type": "blob",
          "accept": ["image/png", "image/jpeg", "image/webp", "audio/mpeg", "audio/wav", "video/mp4"],
          "maxSize": 50000000
        },
        "mimeType": {
          "type": "string",
          "maxLength": 128,
          "description": "The MIME type of the media"
        },
        "alt": {
          "type": "string",
          "maxLength": 1000,
          "description": "Alt text for accessibility"
        },
        "caption": {
          "type": "string",
          "maxLength": 500,
          "description": "Caption for the media"
        },
        "duration": {
          "type": "integer",
          "description": "Duration in seconds for audio/video"
        }
      }
    }
  }
}
