{
  "lexicon": 1,
  "id": "world.ptah.event",
  "defs": {
    "main": {
      "type": "record",
      "description": "Where competition becomes history. A structured occurrence with participants, stakes, results, and witnesses.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["name", "creatorDID", "worldReference", "createdAt"],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 640,
            "maxGraphemes": 64,
            "description": "The name of the event"
          },
          "creatorDID": {
            "type": "string",
            "format": "did",
            "description": "The permanent identity of the event's creator"
          },
          "worldReference": {
            "type": "string",
            "format": "at-uri",
            "description": "Reference to the world this event occurs in"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "Timestamp when this event was created"
          },
          "description": {
            "type": "string",
            "maxLength": 10240,
            "maxGraphemes": 1024,
            "description": "What this event is about"
          },
          "locationReference": {
            "type": "string",
            "format": "at-uri",
            "description": "Reference to the location where this event takes place"
          },
          "eventType": {
            "type": "string",
            "knownValues": ["competition", "gathering", "milestone", "ceremony", "conflict"],
            "description": "The type of event"
          },
          "status": {
            "type": "string",
            "knownValues": ["scheduled", "active", "completed", "cancelled"],
            "description": "The current status of the event"
          },
          "startTime": {
            "type": "string",
            "format": "datetime",
            "description": "When the event begins"
          },
          "endTime": {
            "type": "string",
            "format": "datetime",
            "description": "When the event ends"
          },
          "stakes": {
            "type": "string",
            "maxLength": 10240,
            "maxGraphemes": 1024,
            "description": "What is at stake in this event"
          },
          "result": {
            "type": "string",
            "maxLength": 10240,
            "maxGraphemes": 1024,
            "description": "The outcome of the event"
          },
          "participants": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "at-uri"
            },
            "description": "References to character records participating in this event"
          },
          "witnesses": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "at-uri"
            },
            "description": "References to witness action records — verifiable attendance"
          },
          "canonicalStatus": {
            "type": "string",
            "knownValues": [
              "world.ptah.defs#canonicalStatusOfficial",
              "world.ptah.defs#canonicalStatusCommunity",
              "world.ptah.defs#canonicalStatusApocryphal"
            ],
            "description": "The canonical standing of this event"
          }
        }
      }
    }
  }
}
